PORT=8080
MONGO_DB=
MONGO_DB_NAME=crikoptions_local
JWT_SECRET=change_me
TOKEN_HOURS=24
ADMIN_EMAILS=karan123456789098765@gmail.com
CHAT_ENABLED=false
ALLOWED_ORIGINS=http://localhost:3000

# Match simulator (CSV replay on server start)
SIMULATOR_ENABLED=true
SIMULATOR_AUTO_START=true
SIMULATOR_AUTO_LOOP=true
# Reset built-in simulator matches on API boot. Set false to resume persisted state.
SIMULATOR_RESET_ON_BOOT=true
SIMULATOR_DATA_DIR=./data/simulator
# Seconds between balls; overrides CSV delay_sec when set (default 15 in CSV)
SIMULATOR_DEFAULT_INTERVAL_SEC=4
