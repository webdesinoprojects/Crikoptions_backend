PORT=8080
MONGO_DB=mongodb://127.0.0.1:27017/?replicaSet=rs0&directConnection=true
MONGO_DB_NAME=crikoptions_local
JWT_SECRET=change_me
TOKEN_HOURS=24
ADMIN_EMAILS=admin@example.com
CHAT_ENABLED=false
ALLOWED_ORIGINS=http://localhost:3000,https://cricoptions.vercel.app

# Match simulator (disabled locally to prevent accidental production writes)
SIMULATOR_ENABLED=false
SIMULATOR_AUTO_START=false
SIMULATOR_AUTO_LOOP=false
# Reset built-in simulator matches on API boot. Set false to resume persisted state.
SIMULATOR_RESET_ON_BOOT=false
SIMULATOR_DATA_DIR=./data/simulator
# Seconds between balls; overrides CSV delay_sec when set (default 15 in CSV)
SIMULATOR_DEFAULT_INTERVAL_SEC=4
# Standby instances retry the distributed lock at this interval.
SIMULATOR_AUTO_START_RETRY_SEC=15

# Sportmonks Cricket v2. Keep the token in your deployment secret store.
SPORTMONKS_MODE=off
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://cricket.sportmonks.com/api/v2.0
SPORTMONKS_HTTP_TIMEOUT=15s
SPORTMONKS_HOURLY_REQUEST_LIMIT=2000
SPORTMONKS_QUOTA_RESERVE_PERCENT=20
SPORTMONKS_MAX_CONCURRENCY=4
SPORTMONKS_DISCOVERY_INTERVAL=30s
SPORTMONKS_FIXTURE_SYNC_INTERVAL=6h
SPORTMONKS_METADATA_SYNC_INTERVAL=24h
SPORTMONKS_MIN_POLL_INTERVAL=5s
SPORTMONKS_MAX_POLL_INTERVAL=15s
SPORTMONKS_BREAK_INTERVAL=60s
SPORTMONKS_PREMATCH_INTERVAL=120s
SPORTMONKS_FINALIZING_INTERVAL=15s
SPORTMONKS_LEASE_TTL=30s
SPORTMONKS_STALE_MINIMUM=20s
SPORTMONKS_ACTIVE_FREEZE_TIMEOUT=90s
SPORTMONKS_MATCH_FINALIZATION_HOLD=120s
SPORTMONKS_INNINGS_FINALIZATION_HOLD=60s
SPORTMONKS_RAW_PAYLOAD_TTL=720h
# Keep both false until shadow-mode evidence validates the behavior.
SPORTMONKS_FAST_POLLING_ENABLED=false
SPORTMONKS_ALLOW_LIVE_CORRECTIONS=false
SPORTMONKS_ALLOW_MID_MATCH_LIVE_ADMISSION=false
